# Normalize line endings
* text=auto eol=lf

# Keep Windows scripts with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Kotlin/Gradle
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf

# XML/JSON
*.xml text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.keystore binary
*.jks binary
*.aab binary
*.apk binary
